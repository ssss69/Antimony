{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/api/config",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/assistant_web.html", "destination": "/index.html" },
    { "source": "/otakus_cloud", "destination": "/otakus_cloud.html" },
    { "source": "/writing_zone", "destination": "/writing_zone.html" }
  ]
}
